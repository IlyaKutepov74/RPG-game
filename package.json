{
  "name": "rpg-game",
  "version": "1.0.0",
  "description": "Игра в жанре RPG на JavaScript",
  "main": "index.js",
  "scripts": {
    "build": "webpack --mode production",
    "start": "http-server dist",
    "lint": "eslint .",
    "test": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IlyaKutepov74/RPG-game.git"
  },
  "keywords": [
    "rpg",
    "game",
    "javascript"
  ],
  "author": "Ilya Kutepov",
  "license": "ISC",
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/preset-env": "^7.29.7",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "ajv": "^8.12.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^7.1.4",
    "eslint": "^10.4.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.31.0",
    "html-webpack-plugin": "^5.6.7",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.9.2",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "core-js": "^3.49.0"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "useBuiltIns": "usage",
          "corejs": 3,
          "modules": false
        }
      ]
    ],
    "env": {
      "test": {
        "plugins": [
          "@babel/plugin-transform-modules-commonjs"
        ]
      }
    }
  },
  "jest": {
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    }
  }
}
